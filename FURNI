<base target="_blank">
</head>
<body>
    <!-- 3D Canvas -->
    <div id="canvas-container"></div>

    <!-- Loading Screen -->
    <div id="loading-screen" class="loading-overlay">
        <div class="loading-spinner"></div>
        <p class="mt-4 text-gray-400">جاري تحميل المصمم ثلاثي الأبعاد...</p>
        <div class="progress-bar"><div id="loading-progress" class="progress-fill" style="width: 0%"></div></div>
    </div>

    <!-- UI Overlay -->
    <div class="ui-overlay flex">
        <!-- Left Sidebar -->
        <div class="sidebar p-4 flex flex-col gap-4">
            <!-- Logo -->
            <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-pink-500 to-orange-400 flex items-center justify-center text-xl font-bold">F</div>
                <div>
                    <h1 class="text-lg font-bold gradient-text">FurniSketch</h1>
                    <p class="text-xs text-gray-500">Pro 3D</p>
                </div>
            </div>

            <!-- Room Selector -->
            <div class="glass-card p-4">
                <h3 class="text-sm font-bold mb-3 text-gray-400">🏠 اختاري الغرفة</h3>
                <div class="flex flex-wrap gap-2">
                    <button onclick="setRoom('bedroom')" id="room-bedroom" class="room-btn active">🛏️ نوم</button>
                    <button onclick="setRoom('living')" id="room-living" class="room-btn">🛋️ معيشة</button>
                    <button onclick="setRoom('kitchen')" id="room-kitchen" class="room-btn">🍳 مطبخ</button>
                    <button onclick="setRoom('dining')" id="room-dining" class="room-btn">🍽️ سفرة</button>
                    <button onclick="setRoom('office')" id="room-office" class="room-btn">📚 مكتب</button>
                    <button onclick="setRoom('bathroom')" id="room-bathroom" class="room-btn">🚿 حمام</button>
                </div>
            </div>

            <!-- Furniture List -->
            <div class="glass-card p-4 flex-1">
                <h3 class="text-sm font-bold mb-3 text-gray-400">🪑 الأثاث المتاح</h3>
                <div id="furniture-list" class="flex flex-col gap-2">
                    <!-- Will be populated by JS -->
                </div>
            </div>

            <!-- Description Input -->
            <div class="glass-card p-4">
                <h3 class="text-sm font-bold mb-3 text-gray-400">✨ أو اكتبي وصف</h3>
                <textarea id="description-input" class="input-field text-sm mb-2" rows="3" placeholder="مثال: كنبة زاوية حديثة 3 مقاعد بلوط..."></textarea>
                <button onclick="generateFromDescription()" class="btn-primary w-full text-sm">
                    <i class="fas fa-wand-magic-sparkles ml-2"></i>ولد التصميم
                </button>
            </div>
        </div>

        <!-- Right Panel (Properties) -->
        <div class="sidebar mr-auto p-4 flex flex-col gap-4" style="border-left: none; border-right: 1px solid rgba(255,255,255,0.1);">
            <!-- Selected Object Info -->
            <div class="glass-card p-4">
                <h3 class="text-sm font-bold mb-3 text-gray-400">📋 القطعة المختارة</h3>
                <div id="selected-info" class="text-sm text-gray-300">
                    <p>اختاري قطعة من القايمة على اليسار</p>
                </div>
            </div>

            <!-- Materials -->
            <div class="glass-card p-4">
                <h3 class="text-sm font-bold mb-3 text-gray-400">🪵 الخامة</h3>
                <div class="flex flex-wrap gap-2">
                    <button onclick="setMaterial('oak')" id="mat-oak" class="material-btn active" style="background: linear-gradient(135deg, #8B6914, #A0522D);">
                        <span class="absolute bottom-[-20px] left-1/2 transform -translate-x-1/2 text-[10px] whitespace-nowrap">بلوط</span>
                    </button>
                    <button onclick="setMaterial('walnut')" id="mat-walnut" class="material-btn" style="background: linear-gradient(135deg, #5C4033, #3D2B1F);">
                        <span class="absolute bottom-[-20px] left-1/2 transform -translate-x-1/2 text-[10px] whitespace-nowrap">جوز</span>
                    </button>
                    <button onclick="setMaterial('mdf')" id="mat-mdf" class="material-btn" style="background: linear-gradient(135deg, #F5DEB3, #D2B48C);">
                        <span class="absolute bottom-[-20px] left-1/2 transform -translate-x-1/2 text-[10px] whitespace-nowrap">MDF</span>
                    </button>
                    <button onclick="setMaterial('metal')" id="mat-metal" class="material-btn" style="background: linear-gradient(135deg, #C0C0C0, #808080);">
                        <span class="absolute bottom-[-20px] left-1/2 transform -translate-x-1/2 text-[10px] whitespace-nowrap">معدن</span>
                    </button>
                    <button onclick="setMaterial('leather')" id="mat-leather" class="material-btn" style="background: linear-gradient(135deg, #8B4513, #CD853F);">
                        <span class="absolute bottom-[-20px] left-1/2 transform -translate-x-1/2 text-[10px] whitespace-nowrap">جلد</span>
                    </button>
                    <button onclick="setMaterial('fabric')" id="mat-fabric" class="material-btn" style="background: linear-gradient(135deg, #800080, #4B0082);">
                        <span class="absolute bottom-[-20px] left-1/2 transform -translate-x-1/2 text-[10px] whitespace-nowrap">قماش</span>
                    </button>
                </div>
            </div>

            <!-- Colors -->
            <div class="glass-card p-4">
                <h3 class="text-sm font-bold mb-3 text-gray-400">🎨 اللون</h3>
                <div class="flex flex-wrap gap-2">
                    <button onclick="setColor('#8B4513')" id="color-1" class="color-btn active" style="background: #8B4513;"></button>
                    <button onclick="setColor('#D2691E')" id="color-2" class="color-btn" style="background: #D2691E;"></button>
                    <button onclick="setColor('#F5DEB3')" id="color-3" class="color-btn" style="background: #F5DEB3;"></button>
                    <button onclick="setColor('#2F4F4F')" id="color-4" class="color-btn" style="background: #2F4F4F;"></button>
                    <button onclick="setColor('#708090')" id="color-5" class="color-btn" style="background: #708090;"></button>
                    <button onclick="setColor('#000000')" id="color-6" class="color-btn" style="background: #000000;"></button>
                    <button onclick="setColor('#FFFFFF')" id="color-7" class="color-btn" style="background: #FFFFFF; border: 2px solid rgba(255,255,255,0.3);"></button>
                    <button onclick="setColor('#800080')" id="color-8" class="color-btn" style="background: #800080;"></button>
                    <button onclick="setColor('#FF6347')" id="color-9" class="color-btn" style="background: #FF6347;"></button>
                    <button onclick="setColor('#4169E1')" id="color-10" class="color-btn" style="background: #4169E1;"></button>
                </div>
            </div>

            <!-- Dimensions -->
            <div class="glass-card p-4">
                <h3 class="text-sm font-bold mb-3 text-gray-400">📐 المقاسات (سم)</h3>
                <div class="flex flex-col gap-3">
                    <div>
                        <label class="text-xs text-gray-500">الطول</label>
                        <input type="range" id="dim-length" class="dimension-slider" min="50" max="300" value="200" oninput="updateDimensions()">
                        <span id="val-length" class="text-xs text-gray-400">200</span>
                    </div>
                    <div>
                        <label class="text-xs text-gray-500">العرض</label>
                        <input type="range" id="dim-width" class="dimension-slider" min="50" max="200" value="90" oninput="updateDimensions()">
                        <span id="val-width" class="text-xs text-gray-400">90</span>
                    </div>
                    <div>
                        <label class="text-xs text-gray-500">الارتفاع</label>
                        <input type="range" id="dim-height" class="dimension-slider" min="30" max="250" value="85" oninput="updateDimensions()">
                        <span id="val-height" class="text-xs text-gray-400">85</span>
                    </div>
                </div>
            </div>

            <!-- Finish -->
            <div class="glass-card p-4">
                <h3 class="text-sm font-bold mb-3 text-gray-400">✨ الفينيش</h3>
                <div class="flex flex-wrap gap-2">
                    <button onclick="setFinish('matte')" id="finish-matte" class="tab-btn active">مطفي</button>
                    <button onclick="setFinish('glossy')" id="finish-glossy" class="tab-btn">لامع</button>
                    <button onclick="setFinish('semi')" id="finish-semi" class="tab-btn">نصف لامع</button>
                    <button onclick="setFinish('wood')" id="finish-wood" class="tab-btn">مشجر</button>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex flex-col gap-2">
                <button onclick="deleteSelected()" class="btn-secondary w-full text-sm">
                    <i class="fas fa-trash ml-2"></i>حذف القطعة
                </button>
                <button onclick="clearRoom()" class="btn-secondary w-full text-sm">
                    <i class="fas fa-eraser ml-2"></i>مسح الغرفة
                </button>
                <button onclick="saveDesign()" class="btn-primary w-full text-sm">
                    <i class="fas fa-save ml-2"></i>حفظ التصميم
                </button>
                <button onclick="exportDesign()" class="btn-primary w-full text-sm" style="background: linear-gradient(135deg, #00d2ff, #3a7bd5);">
                    <i class="fas fa-download ml-2"></i>تصدير الصورة
                </button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast" class="toast"></div>

    <!-- Export Modal -->
    <div id="export-modal" class="modal-overlay">
        <div class="modal-content">
            <h2 class="text-2xl font-bold mb-4">📋 تقرير التصميم</h2>
            <div id="export-content" class="text-sm text-gray-300 mb-4 max-h-60 overflow-y-auto"></div>
            <button onclick="closeExport()" class="btn-primary w-full">إغلاق</button>
        </div>
    </div>

