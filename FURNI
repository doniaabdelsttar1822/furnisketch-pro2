        function createStove(group, mat) {
            const body = new THREE.Mesh(new THREE.BoxGeometry(0.6, 0.9, 0.6), new THREE.MeshStandardMaterial({ color: 0x333333, metalness: 0.5 }));
            body.position.y = 0.45;
            group.add(body);

            // Burners
            for (let i = 0; i < 4; i++) {
                const burner = new THREE.Mesh(
                    new THREE.CylinderGeometry(0.08, 0.1, 0.02),
                    new THREE.MeshStandardMaterial({ color: 0x111111 })
                );
                burner.position.set(
                    (i % 2 === 0 ? -0.15 : 0.15),
                    0.91,
                    (i < 2 ? -0.15 : 0.15)
                );
                group.add(burner);
            }

            // Oven door
            const door = new THREE.Mesh(
                new THREE.BoxGeometry(0.5, 0.4, 0.02),
                new THREE.MeshStandardMaterial({ color: 0x111111, metalness: 0.3 })
            );
            door.position.set(0, 0.4, 0.31);
            group.add(door);
        }

        function createCabinet(group, mat) {
            const body = new THREE.Mesh(new THREE.BoxGeometry(0.8, 1.2, 0.4), mat);
            body.position.y = 0.6;
            body.castShadow = true;
            group.add(body);

            // Drawer
            const drawer = new THREE.Mesh(new THREE.BoxGeometry(0.75, 0.35, 0.05), mat);
            drawer.position.set(0, 0.9, 0.22);
            group.add(drawer);

            // Door
            const door = new THREE.Mesh(new THREE.BoxGeometry(0.75, 0.7, 0.05), mat);
            door.position.set(0, 0.4, 0.22);
            group.add(door);
        }

        function createDefaultFurniture(group, mat) {
            const body = new THREE.Mesh(new THREE.BoxGeometry(1, 1, 1), mat);
            body.position.y = 0.5;
            body.castShadow = true;
            group.add(body);
        }

        // Event handlers
        function setupEventListeners() {
            renderer.domElement.addEventListener('click', onMouseClick);
            renderer.domElement.addEventListener('mousedown', onMouseDown);
            renderer.domElement.addEventListener('mousemove', onMouseMove);
            renderer.domElement.addEventListener('mouseup', onMouseUp);
        }

        function onMouseClick(event) {
            if (isDragging) return;

            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(furnitureObjects, true);

            if (intersects.length > 0) {
                let obj = intersects[0].object;
                while (obj.parent && !obj.userData.isFurniture) {
                    obj = obj.parent;
                }
                if (obj.userData.isFurniture) {
                    selectObject(obj);
                }
            } else {
                deselectObject();
            }
        }

        function onMouseDown(event) {
            if (!selectedObject) return;

            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects([selectedObject], true);

            if (intersects.length > 0) {
                isDragging = true;
                controls.enabled = false;

                const intersectPoint = intersects[0].point;
                dragOffset.copy(intersectPoint).sub(selectedObject.position);
            }
        }

        function onMouseMove(event) {
            if (!isDragging || !selectedObject) return;

            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObject(dragPlane);

            if (intersects.length > 0) {
                selectedObject.position.x = intersects[0].point.x - dragOffset.x;
                selectedObject.position.z = intersects[0].point.z - dragOffset.z;
            }
        }

        function onMouseUp() {
            isDragging = false;
            controls.enabled = true;
        }

        function selectObject(obj) {
            deselectObject();
            selectedObject = obj;

            // Highlight
            obj.traverse(child => {
                if (child.isMesh) {
                    child.userData.originalEmissive = child.material.emissive ? child.material.emissive.clone() : new THREE.Color(0,0,0);
                    if (child.material.emissive) {
                        child.material.emissive.setHex(0x444444);
                    }
                }
            });

            updateSelectedInfo();
        }

        function deselectObject() {
            if (selectedObject) {
                selectedObject.traverse(child => {
                    if (child.isMesh && child.userData.originalEmissive) {
                        child.material.emissive.copy(child.userData.originalEmissive);
                    }
                });
                selectedObject = null;
                updateSelectedInfo();
            }
        }

        function updateSelectedInfo() {
            const info = document.getElementById('selected-info');
            if (selectedObject) {
                info.innerHTML = `
                    <p><strong>النوع:</strong> ${selectedObject.userData.name}</p>
                    <p><strong>الخامة:</strong> ${selectedObject.userData.material}</p>
                    <p><strong>اللون:</strong> <span style="display:inline-block;width:20px;height:20px;background:${selectedObject.userData.color};border-radius:3px;vertical-align:middle;margin-right:5px;"></span></p>
                    <p><strong>الفينيش:</strong> ${selectedObject.userData.finish}</p>
                    <p class="text-xs text-gray-500 mt-2">💡 اضغطي واسحبي للتحريك</p>
                `;
            } else {
                info.innerHTML = '<p>اختاري قطعة من القايمة أو اضغطي على أي قطعة في الغرفة</p>';
            }
        }

        function updateFurnitureList() {
            const list = document.getElementById('furniture-list');
            const items = furnitureTypes[currentRoom] || [];

            list.innerHTML = items.map(item => `
                <div class="furniture-item" onclick="addFurniture('${item.type}', '${item.name}')">
                    <span class="text-xl">${item.icon}</span>
                    <span class="mr-2">${item.name}</span>
                </div>
            `).join('');
        }

        function addFurniture(type, name) {
            const room = rooms[currentRoom];
            const x = (Math.random() - 0.5) * room.size.width * 0.6;
            const z = (Math.random() - 0.5) * room.size.depth * 0.6;

            const obj = createFurniture(type, name, x, z, 0);
            selectObject(obj);
            showToast(`تمت إضافة ${name}!`);
        }

        function setRoom(room) {
            document.querySelectorAll('.room-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('room-' + room).classList.add('active');
            loadRoom(room);
            showToast(`تم تحميل ${rooms[room].name}`);
        }

        function setMaterial(mat) {
            currentMaterial = mat;
            document.querySelectorAll('.material-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('mat-' + mat).classList.add('active');

            if (selectedObject) {
                applyMaterialToObject(selectedObject);
                selectedObject.userData.material = mat;
                updateSelectedInfo();
            }
        }

        function setColor(color) {
            currentColor = color;
            document.querySelectorAll('.color-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');

            if (selectedObject) {
                applyMaterialToObject(selectedObject);
                selectedObject.userData.color = color;
                updateSelectedInfo();
            }
        }

        function setFinish(finish) {
            currentFinish = finish;
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById('finish-' + finish).classList.add('active');

            if (selectedObject) {
                applyMaterialToObject(selectedObject);
                selectedObject.userData.finish = finish;
                updateSelectedInfo();
            }
        }

        function applyMaterialToObject(obj) {
            const mat = getMaterial();
            obj.traverse(child => {
                if (child.isMesh && !child.userData.isAccent) {
                    child.material = mat.clone();
                }
            });
        }

        function updateDimensions() {
            const length = document.getElementById('dim-length').value;
            const width = document.getElementById('dim-width').value;
            const height = document.getElementById('dim-height').value;

            document.getElementById('val-length').textContent = length;
            document.getElementById('val-width').textContent = width;
            document.getElementById('val-height').textContent = height;

            if (selectedObject) {
                selectedObject.scale.set(length/200, height/85, width/90);
            }
        }

        function deleteSelected() {
            if (selectedObject) {
                scene.remove(selectedObject);
                furnitureObjects = furnitureObjects.filter(obj => obj !== selectedObject);
                selectedObject = null;
                updateSelectedInfo();
                showToast('تم الحذف!');
            }
        }

        function clearRoom() {
            furnitureObjects.forEach(obj => scene.remove(obj));
            furnitureObjects = [];
            selectedObject = null;
            updateSelectedInfo();
            showToast('تم مسح الغرفة!');
        }

        function saveDesign() {
            const design = {
                room: currentRoom,
                furniture: furnitureObjects.map(obj => ({
                    type: obj.userData.type,
                    name: obj.userData.name,
                    x: obj.position.x,
                    z: obj.position.z,
                    rotation: obj.rotation.y,
                    material: obj.userData.material,
                    color: obj.userData.color,
                    finish: obj.userData.finish,
                    scale: {
                        x: obj.scale.x,
                        y: obj.scale.y,
                        z: obj.scale.z
                    }
                }))
            };

            localStorage.setItem('furnisketch_design_' + Date.now(), JSON.stringify(design));
            showToast('تم حفظ التصميم! 💾');
        }

        function exportDesign() {
            const report = [];
            report.push(`<h3>📋 تقرير تصميم ${rooms[currentRoom].name}</h3>`);
            report.push(`<p><strong>تاريخ:</strong> ${new Date().toLocaleString('ar-EG')}</p>`);
            report.push('<hr style="margin: 10px 0; border-color: rgba(255,255,255,0.2);">');
            report.push('<h4>🪑 القطع المستخدمة:</h4>');
            report.push('<ul>');

            furnitureObjects.forEach((obj, i) => {
                const materials = { oak: 'بلوط', walnut: 'جوز', mdf: 'MDF', metal: 'معدن', leather: 'جلد', fabric: 'قماش' };
                const finishes = { matte: 'مطفي', glossy: 'لامع', semi: 'نصف لامع', wood: 'مشجر' };

                report.push(`<li style="margin: 8px 0;">`);
                report.push(`<strong>${i+1}. ${obj.userData.name}</strong><br>`);
                report.push(`الخامة: ${materials[obj.userData.material] || obj.userData.material}<br>`);
                report.push(`اللون: <span style="display:inline-block;width:15px;height:15px;background:${obj.userData.color};border-radius:3px;vertical-align:middle;"></span> ${obj.userData.color}<br>`);
                report.push(`الفينيش: ${finishes[obj.userData.finish] || obj.userData.finish}<br>`);
                report.push(`المقاسات: ${(obj.scale.x * 200).toFixed(0)}×${(obj.scale.z * 90).toFixed(0)}×${(obj.scale.y * 85).toFixed(0)} سم`);
                report.push('</li>');
            });

            report.push('</ul>');
            report.push(`<p style="margin-top: 15px;"><strong>الإجمالي: ${furnitureObjects.length} قطعة</strong></p>`);

            document.getElementById('export-content').innerHTML = report.join('');
            document.getElementById('export-modal').classList.add('active');
        }

        function closeExport() {
            document.getElementById('export-modal').classList.remove('active');
        }

        function generateFromDescription() {
            const desc = document.getElementById('description-input').value.trim().toLowerCase();
            if (!desc) {
                showToast('اكتبي وصف الأول!');
                return;
            }

            // Simple keyword matching
            const keywords = {
                'سرير': 'bed', 'bed': 'bed',
                'كنبة': 'sofa', 'sofa': 'sofa', 'صالون': 'sofa',
                'دولاب': 'wardrobe', 'wardrobe': 'wardrobe',
                'ترابيزة': 'table', 'table': 'table', 'مائدة': 'dining_table',
                'كرسي': 'chair', 'chair': 'chair',
                'مكتب': 'desk', 'desk': 'desk',
                'رف': 'bookshelf', 'bookshelf': 'bookshelf',
                'ثلاجة': 'fridge', 'fridge': 'fridge',
                'بانيو': 'bathtub', 'bathtub': 'bathtub',
                'حوض': 'sink', 'sink': 'sink',
                'مرحاض': 'toilet', 'toilet': 'toilet',
            };

            let matchedType = null;
            let matchedName = '';

            for (const [keyword, type] of Object.entries(keywords)) {
                if (desc.includes(keyword)) {
                    matchedType = type;
                    matchedName = keyword;
                    break;
                }
            }

            if (matchedType) {
                const room = rooms[currentRoom];
                const x = (Math.random() - 0.5) * room.size.width * 0.4;
                const z = (Math.random() - 0.5) * room.size.depth * 0.4;

                const obj = createFurniture(matchedType, matchedName, x, z, 0);
                selectObject(obj);
                showToast(`تم إنشاء ${matchedName} بناءً على الوصف! ✨`);
            } else {
                showToast('لم يتم التعرف على الوصف. جربي كلمات مثل: سرير، كنبة، دولاب...');
            }

            document.getElementById('description-input').value = '';
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        function hideLoading() {
            document.getElementById('loading-screen').style.opacity = '0';
            setTimeout(() => {
                document.getElementById('loading-screen').style.display = 'none';
            }, 500);
        }

        function onWindowResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }

        // Close modal on outside click
        document.getElementById('export-modal').addEventListener('click', (e) => {
            if (e.target === e.currentTarget) closeExport();
        });
    </script>
</body>
</html>
